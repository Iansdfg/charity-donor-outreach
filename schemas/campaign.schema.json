{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/campaign.schema.json",
  "type": "object",
  "required": ["campaign_id", "name", "charity_name", "campaign_type", "as_of_date", "donation_url", "currency"],
  "additionalProperties": false,
  "properties": {
    "campaign_id": {"type": "string", "minLength": 1}, "name": {"type": "string", "minLength": 1},
    "charity_name": {"type": "string", "minLength": 1}, "campaign_type": {"enum": ["annual_fund", "emergency", "capital", "event"]},
    "as_of_date": {"type": "string", "format": "date"}, "donation_url": {"type": "string", "format": "uri", "pattern": "^https://"},
    "currency": {"const": "USD"}, "claims": {"type": "array", "items": {"type": "object"}}, "match": {"type": "object"},
    "relationship_manager": {"type": ["object", "null"]}
  }
}

